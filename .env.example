PORT=4000
MONGO_URI=mongodb://localhost:27017/soroban_compliance
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=60d
BCRYPT_SALT_ROUNDS=12
NODE_ENV=development

# --- Soroban chain adapter (P2) ---
# Adapter selection: 'stub' (default, in-memory) | 'real' (deployed contract)
SOROBAN_ADAPTER=stub
# USE_SOROBAN_STUB=false   # alternative toggle (false => real)

# Deployed contract config (required only when SOROBAN_ADAPTER=real)
RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=CA6KYPPXEUTAP4X6JAEOI37OD2SCKEAUOSV2VN5ICDWCAI4WASFHRSYB
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SERVICE_SECRET=
OWNER_ADDRESS=
FRIENDBOT_URL=https://friendbot.stellar.org

# Bounded tx-confirmation tuning (fixes the old unbounded NOT_FOUND poll)
SOROBAN_TX_TIMEOUT_MS=60000
SOROBAN_TX_POLL_INTERVAL_MS=1000
SOROBAN_TX_POLL_MAX_MS=5000

# --- Custodial key encryption (P3) ---
# AES-256-GCM key for encrypting each officer/company Stellar secret at rest.
# REQUIRED in production. If unset, secrets are stored unencrypted (dev only).
KEY_ENCRYPTION_SECRET=

# Upload mode: 'false' keeps files in memory (no disk writes); set base dir for disk mode.
USE_DISK_UPLOAD=false
# UPLOAD_BASE_DIR=/data
# ALLOWED_MIMETYPES=application/pdf,image/png,image/jpeg
# MAX_UPLOAD_BYTES=10485760
