PORT=4000
MONGO_URI=mongodb://localhost:27017/soroban_compliance
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=60d
BCRYPT_SALT_ROUNDS=12
NODE_ENV=development

# --- Auth hardening (H1 #5) ---
LOGIN_RATE_MAX=10              # failed logins per IP per window before 429
LOGIN_RATE_WINDOW_MS=900000    # 15 min
AUTH_RATE_MAX=30               # register/refresh/exchange-key per IP per window
AUTH_RATE_WINDOW_MS=900000
LOGIN_LOCKOUT_THRESHOLD=5      # failed logins per ACCOUNT before lockout
LOGIN_LOCKOUT_MS=900000        # account lock duration

# Bootstrap the first super_admin (register is guarded — audit C1):
#   SEED_ADMIN_EMAIL=admin@aitt.io SEED_ADMIN_PASSWORD=<>=12 chars> node src/migrations/seed-admin.js
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Soroban chain adapter (P2) ---
# Adapter selection: 'stub' (default, in-memory) | 'real' (deployed contract).
# In NODE_ENV=production the app REFUSES to boot unless this is 'real' (audit C2).
SOROBAN_ADAPTER=stub
# USE_SOROBAN_STUB=false   # alternative toggle (false => real)

# Deployed contract config (required only when SOROBAN_ADAPTER=real; validated at boot)
RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=CA6KYPPXEUTAP4X6JAEOI37OD2SCKEAUOSV2VN5ICDWCAI4WASFHRSYB
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SERVICE_SECRET=
OWNER_ADDRESS=
FRIENDBOT_URL=https://friendbot.stellar.org

# Bounded tx-confirmation tuning (fixes the old unbounded NOT_FOUND poll)
SOROBAN_TX_TIMEOUT_MS=60000
SOROBAN_TX_POLL_INTERVAL_MS=1000
SOROBAN_TX_POLL_MAX_MS=5000
SOROBAN_TX_MAX_RETRIES=3          # rebuild+resubmit attempts on tx_bad_seq

# --- Custodial key encryption (P3, versioned gcm:v1: — H2 #3) ---
# AES-256-GCM key for encrypting each officer/company Stellar secret at rest.
# REQUIRED in production (boot fails without it). Rotate via utils/wallet.rotateKey.
KEY_ENCRYPTION_SECRET=
# Dev-only escape hatch: allow storing custodial secrets UNENCRYPTED when
# KEY_ENCRYPTION_SECRET is unset. Off by default — the app now REFUSES plaintext
# unless you explicitly opt in (audit C2). NEVER set this in production.
ALLOW_PLAINTEXT_KEYS=false

# --- Wallet funding (B5) ---
# Auto-fund freshly-created custodial wallets so they can transact on the real
# chain (testnet friendbot). Default: on in dev, OFF in prod (mainnet has no
# friendbot — see the treasury-funding seam in services/funding.service).
AUTO_FUND_WALLETS=true

# --- File storage (H4 #11) ---
# auto (gridfs if Mongo connected, else disk) | disk | gridfs | memory.
# gridfs survives a multi-instance deploy; disk is single-instance only.
STORAGE_DRIVER=auto
# Legacy toggle still honored when STORAGE_DRIVER=disk:
USE_DISK_UPLOAD=false
# UPLOAD_BASE_DIR=/data
# ALLOWED_MIMETYPES=application/pdf,image/png,image/jpeg
# MAX_UPLOAD_BYTES=10485760

# --- Background scheduler (D12) ---
# Runs the outbox drain, expiry job, and chain<->DB reconcile on intervals, each
# under a distributed lock (multi-instance safe). Default: on in prod, off in dev/test.
ENABLE_SCHEDULER=false
OUTBOX_JOB_INTERVAL_MS=30000       # drain the durable mirror outbox
EXPIRY_JOB_INTERVAL_MS=3600000     # expire certs + raise alerts (hourly)
RECONCILE_JOB_INTERVAL_MS=21600000 # chain<->DB reconcile (6h)
