# .env.production.example — canonical PRODUCTION configuration.
# Copy to `.env` on the production host and fill every <SET_ME>. Do NOT commit the
# filled file. The app FAIL-FAST validates this at boot (src/config/env.js) and
# REFUSES to start if any production guard is violated.

# ---- Runtime mode (audit C2 guards enforce these) ----
NODE_ENV=production
PORT=4000

# In production the app refuses to boot unless the adapter is 'real'
# (a stub here would silently fake the blockchain).
SOROBAN_ADAPTER=real

# ---- Datastore ----
# Rotate the exposed Atlas credentials and use a dedicated least-privilege user.
MONGO_URI=<SET_ME: mongodb+srv://USER:PASS@host/db?retryWrites=true&w=majority>

# ---- Auth / crypto secrets (REQUIRED; boot fails if unset/short) ----
# Generate fresh: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_ACCESS_SECRET=<SET_ME: >=32 random chars>
JWT_ACCESS_TTL=15m            # short-lived access tokens (was 7d)
JWT_REFRESH_TTL=60d
BCRYPT_SALT_ROUNDS=12
# AES-256-GCM key for custodial secret encryption at rest (REQUIRED in prod).
KEY_ENCRYPTION_SECRET=<SET_ME: >=16 random chars>
# Leave OFF in production — never store plaintext custodial keys.
ALLOW_PLAINTEXT_KEYS=false

# ---- Deployed contract (VALIDATED v2 — NOT the old CC4PAMOJ v1) ----
RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=CA6KYPPXEUTAP4X6JAEOI37OD2SCKEAUOSV2VN5ICDWCAI4WASFHRSYB
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# The main-admin key for THIS contract. Use a dedicated prod key, not the fixture.
SERVICE_SECRET=<SET_ME: main-admin Stellar secret for CONTRACT_ID>
OWNER_ADDRESS=<SET_ME: main-admin public key for CONTRACT_ID>
FRIENDBOT_URL=https://friendbot.stellar.org

# ---- Wallet funding ----
# OFF in prod: testnet friendbot doesn't exist on mainnet. Wire the treasury seam
# in services/funding.service for a real network.
AUTO_FUND_WALLETS=false

# ---- File storage (multi-instance safe) ----
STORAGE_DRIVER=gridfs

# ---- Background scheduler (outbox / expiry / reconcile, distributed-locked) ----
ENABLE_SCHEDULER=true
OUTBOX_JOB_INTERVAL_MS=30000
EXPIRY_JOB_INTERVAL_MS=3600000
RECONCILE_JOB_INTERVAL_MS=21600000

# ---- Uploads ----
MAX_UPLOAD_BYTES=10485760
