{
  "info": {
    "name": "AITT Compliance Backend API",
    "description": "AITT (AI Transparency Token) compliance-certification platform. Base URL and JWT token are collection variables. Run Auth > Login first — it auto-saves the accessToken into {{token}}, so every other request is authorized automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://aitt-backend.vercel.app/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "documentId", "value": "", "type": "string" },
    { "key": "certificateId", "value": "", "type": "string" },
    { "key": "proposalId", "value": "", "type": "string" },
    { "key": "companyId", "value": "", "type": "string" },
    { "key": "docHash", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@aitt.io\",\n  \"password\": \"YourStrongPass12+\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b.accessToken) { pm.collectionVariables.set('token', b.accessToken); }",
                  "if (b.refreshToken) { pm.collectionVariables.set('refreshToken', b.refreshToken); }",
                  "pm.test('login ok', () => pm.response.code === 200);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (super_admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"reviewer@aitt.io\",\n  \"password\": \"StrongPass12+\",\n  \"role\": \"sub_admin\"\n}" }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Exchange API key",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/exchange-key", "host": ["{{baseUrl}}"], "path": ["auth", "exchange-key"] },
            "body": { "mode": "raw", "raw": "{\n  \"apiKey\": \"\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Submit document",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/documents", "host": ["{{baseUrl}}"], "path": ["documents"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] },
                { "key": "subject", "value": "Q4 Audit Report", "type": "text" },
                { "key": "filename", "value": "q4-audit.pdf", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "List documents",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/documents?status=&companyId=", "host": ["{{baseUrl}}"], "path": ["documents"], "query": [{ "key": "status", "value": "" }, { "key": "companyId", "value": "" }] }
          }
        },
        {
          "name": "Get document",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/documents/{{documentId}}", "host": ["{{baseUrl}}"], "path": ["documents", "{{documentId}}"] } }
        },
        {
          "name": "Download document file",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/documents/{{documentId}}/file", "host": ["{{baseUrl}}"], "path": ["documents", "{{documentId}}", "file"] } }
        },
        {
          "name": "Verify document by id (public)",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/documents/{{documentId}}/verify", "host": ["{{baseUrl}}"], "path": ["documents", "{{documentId}}", "verify"] } }
        },
        {
          "name": "Verify document by hash (public)",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/documents/verify/{{docHash}}", "host": ["{{baseUrl}}"], "path": ["documents", "verify", "{{docHash}}"] } }
        },
        {
          "name": "Review document (reviewer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/documents/{{documentId}}/review", "host": ["{{baseUrl}}"], "path": ["documents", "{{documentId}}", "review"] },
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"Approved\",\n  \"complianceScore\": 85,\n  \"comment\": \"Looks good\"\n}" }
          }
        },
        {
          "name": "Issue certificate (super_admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/documents/{{documentId}}/issue", "host": ["{{baseUrl}}"], "path": ["documents", "{{documentId}}", "issue"] },
            "body": { "mode": "raw", "raw": "{\n  \"expiryAt\": \"2027-01-01T00:00:00.000Z\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Certificates",
      "item": [
        { "name": "Create certificate", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/certificates", "host": ["{{baseUrl}}"], "path": ["certificates"] }, "body": { "mode": "formdata", "formdata": [{ "key": "certificateName", "value": "ISO 27001", "type": "text" }, { "key": "subject", "value": "Acme Corp", "type": "text" }, { "key": "file", "type": "file", "src": [] }] } } },
        { "name": "Check issued (public)", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/certificates/check", "host": ["{{baseUrl}}"], "path": ["certificates", "check"] }, "body": { "mode": "raw", "raw": "{\n  \"hash\": \"{{docHash}}\"\n}" } } },
        { "name": "Get certificate (public)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/certificates/{{certificateId}}", "host": ["{{baseUrl}}"], "path": ["certificates", "{{certificateId}}"] } } },
        { "name": "Verify certificate (public)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/certificates/{{certificateId}}/verify", "host": ["{{baseUrl}}"], "path": ["certificates", "{{certificateId}}", "verify"] } } },
        { "name": "List all (super_admin)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/certificates/admin/all", "host": ["{{baseUrl}}"], "path": ["certificates", "admin", "all"] } } },
        { "name": "Get by id (super_admin)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/certificates/admin/{{certificateId}}", "host": ["{{baseUrl}}"], "path": ["certificates", "admin", "{{certificateId}}"] } } },
        { "name": "Update (super_admin)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/certificates/admin/{{certificateId}}", "host": ["{{baseUrl}}"], "path": ["certificates", "admin", "{{certificateId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"certificateName\": \"Updated name\",\n  \"subject\": \"Acme Corp\"\n}" } } },
        { "name": "Delete (super_admin)", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/certificates/admin/{{certificateId}}", "host": ["{{baseUrl}}"], "path": ["certificates", "admin", "{{certificateId}}"] } } }
      ]
    },
    {
      "name": "Proposals",
      "item": [
        { "name": "Create proposal", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/proposals", "host": ["{{baseUrl}}"], "path": ["proposals"] }, "body": { "mode": "raw", "raw": "{\n  \"type\": \"RevokeCertificate\",\n  \"title\": \"Revoke cert for doc\",\n  \"description\": \"Reason...\",\n  \"targetRef\": \"{{docHash}}\"\n}" } } },
        { "name": "List proposals", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/proposals", "host": ["{{baseUrl}}"], "path": ["proposals"] } } },
        { "name": "Get proposal", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/proposals/{{proposalId}}", "host": ["{{baseUrl}}"], "path": ["proposals", "{{proposalId}}"] } } },
        { "name": "Sign proposal", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/proposals/{{proposalId}}/sign", "host": ["{{baseUrl}}"], "path": ["proposals", "{{proposalId}}", "sign"] } } },
        { "name": "Reject proposal (super_admin)", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/proposals/{{proposalId}}/reject", "host": ["{{baseUrl}}"], "path": ["proposals", "{{proposalId}}", "reject"] } } }
      ]
    },
    {
      "name": "Governance",
      "item": [
        { "name": "Get governance", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/governance", "host": ["{{baseUrl}}"], "path": ["governance"] } } },
        { "name": "Set threshold (super_admin)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/governance", "host": ["{{baseUrl}}"], "path": ["governance"] }, "body": { "mode": "raw", "raw": "{\n  \"required\": 2,\n  \"total\": 3\n}" } } }
      ]
    },
    {
      "name": "Companies",
      "item": [
        { "name": "Register company (public)", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/companies/register", "host": ["{{baseUrl}}"], "path": ["companies", "register"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"company@acme.io\",\n  \"password\": \"StrongPass12+\",\n  \"contactPhone\": \"+10000000000\"\n}" } } },
        { "name": "Create company (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/companies", "host": ["{{baseUrl}}"], "path": ["companies"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"company@acme.io\"\n}" } } },
        { "name": "List companies", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies", "host": ["{{baseUrl}}"], "path": ["companies"] } } },
        { "name": "List companies with users", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies/with-users", "host": ["{{baseUrl}}"], "path": ["companies", "with-users"] } } },
        { "name": "Get company", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies/{{companyId}}", "host": ["{{baseUrl}}"], "path": ["companies", "{{companyId}}"] } } },
        { "name": "Approve company (super_admin)", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/companies/{{companyId}}/approve", "host": ["{{baseUrl}}"], "path": ["companies", "{{companyId}}", "approve"] } } },
        { "name": "Remove company (super_admin)", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/companies/{{companyId}}", "host": ["{{baseUrl}}"], "path": ["companies", "{{companyId}}"] } } }
      ]
    },
    {
      "name": "Regulators",
      "item": [
        { "name": "Create regulator (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/regulators", "host": ["{{baseUrl}}"], "path": ["regulators"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"EU Regulator\"\n}" } } },
        { "name": "List regulators", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/regulators", "host": ["{{baseUrl}}"], "path": ["regulators"] } } },
        { "name": "Users grouped", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/regulators/users-grouped", "host": ["{{baseUrl}}"], "path": ["regulators", "users-grouped"] } } },
        { "name": "Get regulator", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/regulators/:id", "host": ["{{baseUrl}}"], "path": ["regulators", ":id"] } } },
        { "name": "Promote to regulator_admin", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/regulators/promote", "host": ["{{baseUrl}}"], "path": ["regulators", "promote"] }, "body": { "mode": "raw", "raw": "{\n  \"userId\": \"\"\n}" } } },
        { "name": "Demote regulator_admin", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/regulators/demote", "host": ["{{baseUrl}}"], "path": ["regulators", "demote"] }, "body": { "mode": "raw", "raw": "{\n  \"userId\": \"\"\n}" } } }
      ]
    },
    {
      "name": "Sub-admins",
      "item": [
        { "name": "Invite sub-admin (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/sub-admins", "host": ["{{baseUrl}}"], "path": ["sub-admins"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Reviewer\",\n  \"email\": \"jane@aitt.io\",\n  \"password\": \"StrongPass12+\"\n}" } } },
        { "name": "List sub-admins", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/sub-admins", "host": ["{{baseUrl}}"], "path": ["sub-admins"] } } },
        { "name": "Activate sub-admin", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/sub-admins/:id/activate", "host": ["{{baseUrl}}"], "path": ["sub-admins", ":id", "activate"] } } },
        { "name": "Remove sub-admin", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/sub-admins/:id", "host": ["{{baseUrl}}"], "path": ["sub-admins", ":id"] } } }
      ]
    },
    {
      "name": "Frameworks",
      "item": [
        { "name": "List frameworks", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/frameworks", "host": ["{{baseUrl}}"], "path": ["frameworks"] } } },
        { "name": "Get framework", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/frameworks/:id", "host": ["{{baseUrl}}"], "path": ["frameworks", ":id"] } } }
      ]
    },
    {
      "name": "Templates",
      "item": [
        { "name": "List templates", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/templates", "host": ["{{baseUrl}}"], "path": ["templates"] } } },
        { "name": "Get template", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/templates/:id", "host": ["{{baseUrl}}"], "path": ["templates", ":id"] } } },
        { "name": "Download template", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/templates/:id/download", "host": ["{{baseUrl}}"], "path": ["templates", ":id", "download"] } } },
        { "name": "Create template (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/templates", "host": ["{{baseUrl}}"], "path": ["templates"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Audit template\",\n  \"description\": \"Standard audit\"\n}" } } },
        { "name": "Update template (super_admin)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/templates/:id", "host": ["{{baseUrl}}"], "path": ["templates", ":id"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated\"\n}" } } },
        { "name": "Remove template (super_admin)", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/templates/:id", "host": ["{{baseUrl}}"], "path": ["templates", ":id"] } } }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        { "name": "List alerts", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/alerts", "host": ["{{baseUrl}}"], "path": ["alerts"] } } },
        { "name": "Create alert (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/alerts", "host": ["{{baseUrl}}"], "path": ["alerts"] }, "body": { "mode": "raw", "raw": "{\n  \"message\": \"Certificate expiring soon\",\n  \"severity\": \"warning\"\n}" } } },
        { "name": "Resolve alert", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/alerts/:id/resolve", "host": ["{{baseUrl}}"], "path": ["alerts", ":id", "resolve"] } } }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "List notifications", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/notifications", "host": ["{{baseUrl}}"], "path": ["notifications"] } } },
        { "name": "Mark all read", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/notifications/read-all", "host": ["{{baseUrl}}"], "path": ["notifications", "read-all"] } } },
        { "name": "Mark one read", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/notifications/:id/read", "host": ["{{baseUrl}}"], "path": ["notifications", ":id", "read"] } } }
      ]
    },
    {
      "name": "Soroban (chain)",
      "item": [
        { "name": "Owner address (public)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/soroban/owner", "host": ["{{baseUrl}}"], "path": ["soroban", "owner"] } } },
        { "name": "Read document (public)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/soroban/read/{{docHash}}", "host": ["{{baseUrl}}"], "path": ["soroban", "read", "{{docHash}}"] } } },
        { "name": "Verify (public)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/soroban/verify/{{docHash}}", "host": ["{{baseUrl}}"], "path": ["soroban", "verify", "{{docHash}}"] } } },
        { "name": "Is whitelisted (public)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/soroban/is_whitelisted/:address", "host": ["{{baseUrl}}"], "path": ["soroban", "is_whitelisted", ":address"] } } },
        { "name": "Store document (admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/soroban/store_document", "host": ["{{baseUrl}}"], "path": ["soroban", "store_document"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Q4 Audit\",\n  \"hash\": \"{{docHash}}\"\n}" } } },
        { "name": "Whitelist address (admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/soroban/whitelist", "host": ["{{baseUrl}}"], "path": ["soroban", "whitelist"] }, "body": { "mode": "raw", "raw": "{\n  \"address\": \"G...\"\n}" } } },
        { "name": "Remove whitelist (admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/soroban/remove_whitelist", "host": ["{{baseUrl}}"], "path": ["soroban", "remove_whitelist"] }, "body": { "mode": "raw", "raw": "{\n  \"address\": \"G...\"\n}" } } },
        { "name": "Transfer ownership (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/soroban/transfer_ownership", "host": ["{{baseUrl}}"], "path": ["soroban", "transfer_ownership"] }, "body": { "mode": "raw", "raw": "{\n  \"newOwner\": \"G...\"\n}" } } },
        { "name": "Create wallet (helper)", "request": { "auth": { "type": "noauth" }, "method": "POST", "url": { "raw": "{{baseUrl}}/soroban/helpers/create_wallet", "host": ["{{baseUrl}}"], "path": ["soroban", "helpers", "create_wallet"] } } },
        { "name": "Fund wallet (helper)", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/soroban/helpers/fund_wallet", "host": ["{{baseUrl}}"], "path": ["soroban", "helpers", "fund_wallet"] }, "body": { "mode": "raw", "raw": "{\n  \"publicKey\": \"G...\"\n}" } } },
        { "name": "Init contract (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/soroban/init", "host": ["{{baseUrl}}"], "path": ["soroban", "init"] }, "body": { "mode": "raw", "raw": "{}" } } }
      ]
    },
    {
      "name": "Admin",
      "item": [
        { "name": "Run expiry job (super_admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/admin/jobs/expiry", "host": ["{{baseUrl}}"], "path": ["admin", "jobs", "expiry"] }, "body": { "mode": "raw", "raw": "{\n  \"warnWithinDays\": 30\n}" } } },
        { "name": "List audit (super_admin)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/audit?page=1&limit=50", "host": ["{{baseUrl}}"], "path": ["admin", "audit"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "50" }] } } }
      ]
    },
    {
      "name": "Health",
      "item": [
        { "name": "Health check (root)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "https://aitt-backend.vercel.app/", "protocol": "https", "host": ["aitt-backend", "vercel", "app"], "path": [""] } } }
      ]
    }
  ]
}
